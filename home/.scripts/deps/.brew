#!/usr/bin/env bash

brews=(
  # core
  "bash"      # bash 4
  "coreutils" # OS X GNU core utils are outdated
  "curl"
  "findutils" # GNU find, locate, updatedb, xargs (g-prefixed)
  "git"
  "gnupg"
  "openssl@3"
  "openssl@4"
  "pinentry" # pinentry for gpg

  # shell / prompt / nav
  "anyquery"
  "atuin"
  "carapace"
  "cmake"
  "difftastic" # diffing in lazygit
  "exercism"
  "fd"
  "ffmpeg"
  "fish"
  "fnm"
  "fzf"
  "git-lfs"
  "htop"
  "jq"
  "just"
  "lazygit"
  "mdbook"
  "neovim"
  "nnn"
  "parallel"
  "pass"
  "ripgrep"
  "sevenzip"
  "starship"
  "tealdeer"
  "tfenv" # nvm for Terraform
  "tmux"
  "tmuxinator"
  "tmuxinator-completion"
  "tre-command"
  "vim"
  "xcodegen"
  "zoxide"
  "zsh"

  # languages / runtimes
  "cargo-expand"
  "elm"
  "go"
  "lua"
  "luarocks" # required for neorg
  "pipenv"
  "ptpython"
  "python"
  "rust"
  "rust-analyzer"
  "uv"
  "zig"

  # databases
  "postgresql"
  "sqlite"

  # cloud / infra
  "ansible"
  "ansible-lint"
  "checkov"
  "docker"
  "docker-agent"
  "docker-completion"
  "doctl"
  "flux"
  "glab"
  "newrelic-cli"
  "ollama"
  "openvpn"
  "packer"
  "sentry-cli"

  # networking
  "httpie"
  "telnet"

  # Diagnostics
  "codespell"
  "djlint"
  "dotenv-linter"
  "gopls"
  "gopls"
  "lua-language-server"
  "markdownlint-cli2"
  "ruff"
  "rust-analyzer"
  "shellcheck"
  "shellharden"
  "sleek" # diagnostics for sql
  "tree-sitter"
  "tree-sitter-cli" # nvim-treesitter dependency
  "vint"
  "yamllint"
  "zls"

  # Formatters
  "cbfmt"
  "clang-format"
  "fsouza/prettierd/prettierd"
  "gofumpt"
  "golines"
  "rustfmt"
  "shellharden"
  "shfmt"
  "sqlfluff"
  "stylua"

  # Yabai
  "koekeishiya/formulae/yabai"
  "koekeishiya/formulae/skhd"
)

casks=(
  "1password"
  "1password-cli"
  "a-better-finder-rename"
  "aldente"
  "alfred"
  "apparency"
  "arc"
  "beekeeper-studio"
  "betterzip"
  "claude"
  "claude-code"
  "dash"
  "docker-desktop"
  "figma"
  "firefox"
  "firefox@developer-edition"
  "flameshot"
  "flux-app"
  "font-roboto-mono-nerd-font"
  "ghostty"
  "hammerspoon" # Yabai dependency
  "karabiner-elements"
  "keycastr"
  "keymapp"
  "kitty" # required for image previews in ghostty
  "libreoffice"
  "lihaoyun6/tap/quickrecorder"
  "lulu"
  "postman"
  "proxyman"
  "qlImageSize"
  "qlcolorcode"
  "qlstephen"
  "quicklook-csv"
  "quicklook-json"
  "quicklook-video"
  "rescuetime"
  "safari-technology-preview"
  "skim"
  "suspicious-package"
  "the-unarchiver"
  "transmission"
  "virtualbox"
  "visual-studio-code"
  "vlc"
  "webpquicklook"
  "xbar"
  "xscope"
  "xykong/tap/flux-markdown"
)

# Homebrew 6.0.0+ requires explicit trust for non-official taps before their
# formulae/casks/commands are loaded
# https://docs.brew.sh/Tap-Trust
taps_requiring_trust=(
  "anomalyco/tap/opencode"
  "fsouza/prettierd/prettierd"
  "hashicorp/tap/packer"
  "jesseduffield/lazydocker/lazydocker"
  "jesseduffield/lazynpm/lazynpm"
  "koekeishiya/formulae/skhd"
  "koekeishiya/formulae/yabai"
  "terraform-linters/tap/tflint" # linter for Terraform
)

casks_requiring_trust=(
  "lihaoyun6/tap/quickrecorder"
  "xykong/tap/flux-markdown"
)

custom_taps=(
  "koekeishiya/formulae|https://github.com/asmvik/homebrew-formulae.git"
)

for entry in "${custom_taps[@]}"; do
  tap="${entry%%|*}"
  url="${entry#*|}"
  brew tap "$tap" "$url"
done

for formula in "${taps_requiring_trust[@]}"; do
  brew tap "${formula%/*}"        # idempotent
  brew trust --formula "$formula" # idempotent
done

for cask in "${casks_requiring_trust[@]}"; do
  brew tap "${cask%/*}"
  brew trust --cask "$cask"
done

brew_lines=""
cask_lines=""

NL=$'\n'

for brew in "${brews[@]}"; do
  brew_lines+="brew \"${brew}\"${NL}"
done

if [[ "$(uname -s)" == "Darwin" ]]; then
  for cask in "${casks[@]}"; do
    brew_lines+="cask \"${cask}\"${NL}"
  done
fi

brew bundle --file=/dev/stdin <<EOF
  $brew_lines
  $cask_lines
EOF

echo -e "\nCleaning up..."

brew cleanup
