#!/usr/bin/env bash

brews=(
  "git"

  # Mac OS deps
  "bash"      # bash 4
  "coreutils" # OS X GNU core utils are outdated
  "findutils" # install GNU `find`, `locate`, `updatedb`, and `xargs`, g-prefixed
  "libiconv"  # Mojave deps (TODO: determine if this is still needed)
  "mysql"     # allow for running MySQL commands on machine
  "openldap"  # Mojave deps (TODO: determine if this is still needed)
  "wget"

  "anomalyco/tap/opencode" # up-to-date version of opencode
  "ansible"
  "ansible-lint"
  "ariga/tap/atlas" # Terraform-like orchestration for db schemas
  "atuin"
  "bat"
  "bats-core"
  "carapace"
  "checkmake"
  "checkov"
  "clang-format"
  "cppcheck"
  "ctop"
  "difftastic"
  "dive"
  "dust"
  "editorconfig"
  "elm"
  "elm-format"
  "fd"
  "fluent-bit"
  "fx" # jq alternative
  "fzf"
  "gemini-cli"
  "git"
  "git-flow"
  "gitlab-runner"
  "go"
  "go-task"
  "gofumpt"
  "golines"
  "gopls"
  "gpg"
  "htop"
  "hurl"
  "imagemagick"
  "jesseduffield/lazydocker/lazydocker"
  "jesseduffield/lazynpm/lazynpm"
  "jid"
  "jq"
  "just"
  "lazygit"
  "lynx"
  "mpv"
  "neovim"
  "fnm"
  "ollama"
  "oven-sh/bun/bun"
  "packer"
  "parallel"
  "pass"
  "peterldowns/tap/nix-search-cli"
  "pigz"
  "pinentry-mac" # dep for gpg to use Mac's keychain for pass-phrases
  "poppler"
  "postgresql"
  "posting"
  "ptpython"
  "pyenv"
  "pyenv-virtualenv"
  "python"
  "qt"
  "redis"
  "ripgrep"
  "ruff"
  "sevenzip"
  "starship"
  "tealdeer"
  "tfenv"  # nvm for Terraform
  "tflint" # linter for Terraform
  "tmux"
  "tmuxinator"
  "tokei"
  "tre-command"
  "tree-sitter-cli" # nvim-treesitter dependency
  "tursodatabase/tap/turso"
  "uv"
  "vim"
  "watchexec"
  "webkit2png"
  "xh" # httpie alternative
  "yarn"
  "zopfli"
  "zoxide"

  # Lua
  "lua"
  "luarocks" # required for neorg
  "lua-language-server"

  # Rust
  "cargo-expand"

  # Yabai
  "koekeishiya/formulae/yabai"
  "koekeishiya/formulae/skhd"

  # zig
  "zig"
  "zls"

  # Formatters
  "cbfmt"
  "fsouza/prettierd/prettierd"
  "rustfmt"
  "shellharden"
  "shfmt"
  "sqlfluff"
  "stylua"

  # Diagnostics
  "alejandra"   # nix formatter. TODO: install using flakes
  "codeclimate" # requires tapping codeclimate/formulae
  "codespell"
  "djlint"
  "dotenv-linter"
  "golangci-lint"
  "hadolint"
  "markdownlint-cli2"
  "rust-analyzer"
  "shellcheck"
  "sleek" # diagnostics for sql
  "vint"
  "yamllint"
)

casks=(
  "1password"
  "1password-cli"
  "a-better-finder-rename"
  "aldente"
  "alfred"
  "apparency"
  "arc"
  "beekeeper-studio"
  "betterzip"
  "claude"
  "claude-code"
  "dash"
  "docker-desktop"
  "figma"
  "firefox"
  "flameshot"
  "flux-app"
  "font-roboto-mono-nerd-font"
  "ghostty"
  "hammerspoon" # Yabai dependency
  "homebrew/cask-versions/firefox-developer-edition"
  "karabiner-elements"
  "keycastr"
  "keymapp"
  "kitty" # required for image previews in ghostty
  "libreoffice"
  "lihaoyun6/tap/quickrecorder"
  "lulu"
  "postman"
  "proxyman"
  "qlImageSize"
  "qlcolorcode"
  "xykong/tap/flux-markdown"
  "qlstephen"
  "quicklook-video"
  "quicklook-csv"
  "quicklook-json"
  "rescuetime"
  "safari-technology-preview"
  "skim"
  "suspicious-package"
  "the-unarchiver"
  "transmission"
  "virtualbox"
  "visual-studio-code"
  "vlc"
  "webpquicklook"
  "xbar"
  "xscope"
)

# Homebrew 6.0.0+ requires explicit trust for non-official taps before their
# formulae/casks/commands are loaded
# https://docs.brew.sh/Tap-Trust
taps_requiring_trust=(
  "anomalyco/tap/opencode"
  "ariga/tap/atlas"
  "codeclimate/formulae/codeclimate"
  "fsouza/prettierd/prettierd"
  "jesseduffield/lazydocker/lazydocker"
  "jesseduffield/lazynpm/lazynpm"
  "koekeishiya/formulae/yabai"
  "koekeishiya/formulae/skhd"
  "oven-sh/bun/bun"
  "peterldowns/tap/nix-search-cli"
  "tursodatabase/tap/turso"
)

casks_requiring_trust=(
  "lihaoyun6/tap/quickrecorder"
  "xykong/tap/flux-markdown"
)

custom_taps=(
  "codeclimate/formulae|https://github.com/qltysh-archive/homebrew-formulae.git"
  "koekeishiya/formulae|https://github.com/asmvik/homebrew-formulae.git"
)

for entry in "${custom_taps[@]}"; do
  tap="${entry%%|*}"
  url="${entry#*|}"
  brew tap "$tap" "$url"
done

for formula in "${taps_requiring_trust[@]}"; do
  brew tap "${formula%/*}"        # idempotent
  brew trust --formula "$formula" # idempotent
done

for cask in "${casks_requiring_trust[@]}"; do
  brew tap "${cask%/*}"
  brew trust --cask "$cask"
done

brew_lines=""
cask_lines=""

NL=$'\n'

for brew in "${brews[@]}"; do
  brew_lines+="brew \"${brew}\"${NL}"
done

if [[ "$(uname -s)" == "Darwin" ]]; then
  for cask in "${casks[@]}"; do
    brew_lines+="cask \"${cask}\"${NL}"
  done
fi

brew bundle --file=/dev/stdin <<EOF
  $brew_lines
  $cask_lines
EOF

brew cleanup
