# .exports - Fast static environment variables only
# This file should contain ONLY export statements, no executable code

# XDG Base Directory Specification
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$XDG_CONFIG_HOME/local/share"
export XDG_CACHE_HOME="$XDG_CONFIG_HOME/cache"

# make Neovim the editor for applications such as tmux, nnn, etc.
export EDITOR="nvim"

# Larger bash history (allow 32³ entries; default is 500)
export HISTSIZE=32768
export HISTFILESIZE=32768
export HISTCONTROL=ignoredups
# Make some commands not show up in history
export HISTIGNORE="ls:cd:cd -:pwd:exit:date:* --help"

# Prefer British English and use UTF-8
export LANG="en_GB"
export LC_ALL="en_GB.UTF-8"

# Highlight section titles in manual pages
export LESS_TERMCAP_md="$ORANGE"

# use Neovim for man pages
if type -p "nvim" >/dev/null; then
  export MANPAGER="nvim +Man\!"
# otherwise use bat to syntax highlight man pages
elif type -p "bat" >/dev/null; then
  export MANPAGER="sh -c 'col -bx | bat -l man -p'"
else
  export MANPAGER="less --incsearch"
fi

# Homebrew
export HOMEBREW_CASK_OPTS="--appdir=/Applications"

# fzf
export FZF_DEFAULT_COMMAND='fd --type f --strip-cwd-prefix --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"

# Tool-specific
export PTPYTHON_CONFIG_HOME="$HOME/.config/ptpython"

# NVM (export directory only, no loading)
export NVM_DIR="$HOME/.nvm"

# OpenCode - enable LSP support
export OPENCODE_EXPERIMENTAL_LSP_TOOL=true

# PATH - Static additions only
# Homebrew bins (macOS)
export PATH="/usr/local/bin:$PATH"
export PATH="/opt/homebrew/bin:$PATH"

# Linux Homebrew
if [[ "$(uname -s)" == "Linux" ]]; then
  export PATH="/home/linuxbrew/.linuxbrew/bin:$PATH"
  export PATH="/home/linuxbrew/.linuxbrew/sbin:$PATH"
fi

# Add `~/bin` to the `$PATH`
export PATH="$HOME/bin:$PATH"

# Development tools (only add if they exist to avoid PATH pollution)
# Google's depot_tools for Chrome iOS Simulator
# Installation: https://chromium.googlesource.com/chromium/src/+/master/docs/ios/build_instructions.md
[[ -d "$HOME/code/depot_tools" ]] && export PATH="$HOME/code/depot_tools:$PATH"

# Rust cargo binaries
[[ -d "$HOME/.cargo/bin" ]] && export PATH="$HOME/.cargo/bin:$PATH"

# uv Python package installer
[[ -d "$HOME/.config/local/share/../bin" ]] && export PATH="$HOME/.config/local/share/../bin:$PATH"

# Go binaries
[[ -d "$HOME/go/bin" ]] && export PATH="$HOME/go/bin:$PATH"

# Go configuration
if [[ "$(uname -s)" == "Darwin" ]]; then
  export GOPATH="$HOME/golang"
elif [[ "$(uname -s)" == "Linux" ]]; then
  export GOPATH="/usr/local/go"
fi
[[ -d "$GOPATH/bin" ]] && export PATH="$PATH:$GOPATH/bin"

# vim: set filetype=sh:
